DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL blank to use local SQLite.
# Example PostgreSQL URL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db
DATABASE_URL=
DJANGO_DB_SSL_REQUIRE=false

JWT_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: encrypt saved provider API keys.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Background jobs.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional social login provider credentials.
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional provider endpoint overrides.
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
MISTRAL_BASE_URL=https://api.mistral.ai/v1
XAI_BASE_URL=https://api.x.ai/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1
LLAMA_BASE_URL=https://api.llama.com/compat/v1
OTHER_LLM_BASE_URL=https://api.openai.com/v1
